# Create a data frame

exam_data <- data.frame(
  name = c("Arun", "Bala", "Charan", "Divya", "Esha"),
  score = c(85, 67, 92, 74, 88),
  attempts = c(1, 2, 1, 3, 2),
  qualify = c("Yes", "Yes", "Yes", "No", "Yes")
)

# Display the data frame
print(exam_data)

# Extract the score column
print(exam_data$score)

# Extract the first two rows
print(exam_data[1:2, ])

# Add a new row
new_student <- data.frame(
  name = "Ganesh",
  score = 95,
  attempts = 1,
  qualify = "Yes"
)

exam_data <- rbind(exam_data, new_student)

# Add a new column
exam_data$Grade <- c("A", "B", "A+", "C", "A", "A+")

# Display updated data frame
print(exam_data)

# Sort by score (highest to lowest)
sorted_data <- exam_data[order(exam_data$score, decreasing = TRUE), ]

print(sorted_data)

# Save data frame to a CSV file
write.csv(sorted_data, "exam_data.csv", row.names = FALSE)

cat("Data saved successfully to exam_data.csv")
