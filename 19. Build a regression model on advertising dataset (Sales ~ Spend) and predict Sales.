# Create Advertising dataset

advertising <- data.frame(
  Spend = c(20, 30, 40, 50, 60, 70, 80, 90, 100, 110),
  Sales = c(25, 30, 35, 40, 45, 50, 55, 60, 65, 70)
)

# Display dataset
print(advertising)

# Build Linear Regression Model
model <- lm(Sales ~ Spend, data = advertising)

# Display model summary
summary(model)

# Predict Sales for new advertising spends
new_data <- data.frame(Spend = c(45, 75, 95))

predicted_sales <- predict(model, newdata = new_data)

# Display predictions
result <- data.frame(
  Spend = new_data$Spend,
  Predicted_Sales = predicted_sales
)

print(result)

# Plot the data and regression line
plot(advertising$Spend,
     advertising$Sales,
     main = "Sales vs Advertising Spend",
     xlab = "Advertising Spend",
     ylab = "Sales",
     pch = 19,
     col = "blue")

abline(model, col = "red", lwd = 2)
